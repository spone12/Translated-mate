       <string notr="true">#sourceLangList {
    font: 11pt Fira Sans Condensed;     
    background-color: #2e2e2e;
    border-top: 0px solid #3e3e3e;
    border-left: 0px solid #3e3e3e;
    border-right: 0px solid #3e3e3e;
    border-bottom: 2px solid #3e3e3e;
    padding: 5%;
    max-height: 30px;
    min-width: 140px;
    color: white;
    selection-background-color: #5e5e5e;
	border-radius: 2px;
}
#sourceLangList:drop-down {
    border: none;
}
#sourceLangList:down-arrow {
    image: url(img/downButton.png);
    width: 25px;
    height: 25px;
    border-width: 0px;
    padding-right: 10px;
}

#sourceLangList:pressed {
    position: relative;
    top: 1px; left: 1px;
}</string>
